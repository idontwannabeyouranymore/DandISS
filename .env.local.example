# =====================================================================
# DandISS — variables de entorno
# Copia este archivo a `.env.local` y rellena con los valores de tu
# proyecto Supabase (Dashboard -> Project Settings -> API).
# =====================================================================

# Cliente público (expuesto al navegador). Seguro: la seguridad la aplica RLS.
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Solo servidor. NUNCA la expongas al cliente ni la subas a git.
# Se usa para: calcular slots libres (lee citas saltándose RLS) y crear
# usuarios de estilistas desde el panel del dueño.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Zona horaria del negocio (para calcular y mostrar horarios de citas).
NEXT_PUBLIC_SHOP_TIMEZONE=America/Mexico_City
